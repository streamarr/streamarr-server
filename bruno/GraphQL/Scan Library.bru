meta {
  name: Scan Library
  type: graphql
  seq: 4
}

post {
  url: {{BASE_URL}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  mutation ScanLibrary($id: ID!) {
    scanLibrary(id: $id)
  }
}

body:graphql:vars {
  {
    "id": "{{LIBRARY_ID}}"
  }
}

tests {
  test("Should start a library scan", function() {
    expect(res.status).to.equal(200);
    expect(res.body).to.not.have.property("errors");
    expect(res.body.data.scanLibrary).to.equal(true);
  });
}
