meta {
  name: Refresh Library
  type: graphql
  seq: 5
}

post {
  url: {{BASE_URL}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  mutation RefreshLibrary($id: ID!) {
    refreshLibrary(id: $id)
  }
}

body:graphql:vars {
  {
    "id": "{{LIBRARY_ID}}"
  }
}

tests {
  test("Should start a library refresh", function() {
    expect(res.status).to.equal(200);
    expect(res.body).to.not.have.property("errors");
    expect(res.body.data.refreshLibrary).to.equal(true);
  });
}
