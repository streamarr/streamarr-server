meta {
  name: Get Libraries
  type: graphql
  seq: 1
}

post {
  url: {{BASE_URL}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  query {
    libraries {
      id
      name
      alphabetIndex {
        letter
        count
      }
    }
  }
}

tests {
  test("Should return libraries", function() {
    expect(res.status).to.equal(200);
    expect(res.body).to.not.have.property("errors");
    expect(res.body.data.libraries).to.be.an("array");
  });
}
