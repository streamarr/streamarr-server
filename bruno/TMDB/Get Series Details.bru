meta {
  name: Get Series Details
  type: http
  seq: 2
}

get {
  url: {{TMDB_BASE_URL}}/tv/2730?append_to_response=content_ratings,credits,external_ids
  body: none
  auth: inherit
}

params:query {
  append_to_response: content_ratings,credits,external_ids
}

headers {
  accept: application/json
}

tests {
  test("Should return TMDB series details", function() {
    expect(res.status).to.equal(200);
    expect(res.body.id).to.be.a("number");
  });
}
