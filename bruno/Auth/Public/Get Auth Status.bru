meta {
  name: Get Auth Status
  type: http
  seq: 1
  tags: [
    public
  ]
}

get {
  url: {{BASE_URL}}/api/auth/status
  body: none
  auth: none
}

tests {
  test("Should return setup status", function() {
    expect(res.status).to.equal(200);
    expect(res.body.setupComplete).to.be.a("boolean");
  });
}
