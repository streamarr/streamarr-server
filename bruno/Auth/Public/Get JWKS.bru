meta {
  name: Get JWKS
  type: http
  seq: 2
  tags: [
    public
  ]
}

get {
  url: {{BASE_URL}}/.well-known/jwks.json
  body: none
  auth: none
}

tests {
  test("Should return signing keys", function() {
    expect(res.status).to.equal(200);
    expect(res.body.keys).to.be.an("array").that.is.not.empty;
  });
}
